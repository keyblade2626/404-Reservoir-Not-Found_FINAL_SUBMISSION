    EvaluationFrequency=ALWAYS
    EvaluationPeriod=1
    PeriodCount=0
    VerbosityLevel=1
}

Expression "Type_PRODUCER_Selection_Criterion" {
    Definition="Type == PRODUCER"
    EvaluationFrequency=ALWAYS
    EvaluationPeriod=1
    PeriodCount=0
    VerbosityLevel=1
}

Expression "Type_WATER_INJECTOR_Selection_Criterion" {
