    EvaluationFrequency=ALWAYS
    EvaluationPeriod=1
    PeriodCount=0
    VerbosityLevel=1
}

Expression "ClosureReason_NOT_USER_Selection_Criterion" {
    Definition="ClosureReason != USER"
    EvaluationFrequency=ALWAYS
    EvaluationPeriod=1
    PeriodCount=0
    VerbosityLevel=1
}

Expression "ClosureReason_OPEN_or_BEING_DRILLED_Selection_Criterion" {
    Definition="(Status == OPEN) | (ClosureReason == BEING_DRILLED)"
    EvaluationFrequency=ALWAYS
    EvaluationPeriod=1
    PeriodCount=0
    VerbosityLevel=1
}

Expression "Status_CLOSED_Selection_Criterion" {
    Definition="Status != OPEN"
    EvaluationFrequency=ALWAYS
    EvaluationPeriod=1
    PeriodCount=0
    VerbosityLevel=1
}

Expression "Status_NOT_ABANDONED_Selection_Criterion" {
