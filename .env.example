# 404 Reservoir Not Found - Environment Template
#
# Copy this file to .env only if you want to enable Compass/LLM calls.
#
# Windows PowerShell:
#   copy .env.example .env
#
# Then replace the placeholder below with your own Compass API key.
#
# IMPORTANT:
# - Do NOT commit .env
# - Do NOT upload .env to GitHub
# - .env is intentionally ignored by .gitignore and .dockerignore
#
# The demo dashboard can run without COMPASS_API_KEY.
# The AI chatbox / Compass generation requires COMPASS_API_KEY at runtime.

COMPASS_API_KEY=your_compass_api_key_here

# Runtime settings
HOST=0.0.0.0
PORT=8000
